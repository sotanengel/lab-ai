    "@lab-ai/shared": "workspace:*",
    "drizzle-orm": "0.45.2",
    "exceljs": "4.4.0",
    "hono": "4.12.14",
    "nanoid": "5.0.9",
    "pino": "9.5.0",
    "unpdf": "0.12.1",
    "zod": "3.23.8"
  },
  "devDependencies": {
    "@types/node": "20.16.13",
    "@vitest/coverage-v8": "2.1.4",
    "tsx": "4.19.1",
