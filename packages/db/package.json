{
  "name": "@lab-ai/db",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts"
    },
    "./schema": {
      "types": "./src/schema.ts",
      "import": "./src/schema.ts"
    }
  },
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "scripts": {
    "build": "tsc -b",
    "typecheck": "tsc --noEmit",
    "generate": "drizzle-kit generate",
    "migrate": "tsx src/migrate.ts",
    "test": "vitest run --passWithNoTests"
  },
  "dependencies": {
    "better-sqlite3": "11.3.0",
    "drizzle-orm": "0.36.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "7.6.11",
    "@types/node": "20.16.13",
    "drizzle-kit": "0.28.0",
    "tsx": "4.19.1",
    "typescript": "5.6.3",
    "vitest": "2.1.4"
  }
}
