{
  "name": "lab-ai",
  "version": "0.1.0",
  "private": true,
  "description": "Researcher Experiment Analysis Platform",
  "license": "MIT",
  "packageManager": "pnpm@9.12.0",
  "engines": {
    "node": ">=20.11.0"
  },
  "scripts": {
    "build": "pnpm -r --filter './packages/*' --filter './apps/*' run build",
    "dev": "pnpm -r --parallel run dev",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "format": "biome format --write .",
    "test": "pnpm -r run test",
    "typecheck": "pnpm -r run typecheck",
    "db:generate": "pnpm --filter @lab-ai/db run generate",
    "db:migrate": "pnpm --filter @lab-ai/db run migrate"
  },
  "devDependencies": {
    "@biomejs/biome": "1.9.4",
    "typescript": "5.6.3",
    "vitest": "2.1.4"
  }
}
